# Copy to .env and fill in. .env is gitignored - never commit real secrets.

# --- AWS (local dev via IAM Identity Center / SSO; no long-lived keys) ---
# boto3 reads temporary creds from the SSO profile; run
# `aws sso login --profile <name>` once per session to refresh them.
AWS_PROFILE=instacart
AWS_DEFAULT_REGION=us-east-1
S3_BUCKET=

# --- Snowflake ---
SNOWFLAKE_ACCOUNT=          # e.g. ORGNAME-ACCOUNT (Snowsight > account details)
SNOWFLAKE_USER=
SNOWFLAKE_PASSWORD=
SNOWFLAKE_ROLE=INSTACART_ROLE
SNOWFLAKE_WAREHOUSE=INSTACART_WH
SNOWFLAKE_DATABASE=INSTACART
