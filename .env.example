# Copy to .env and fill in. .env is gitignored — never commit real secrets.

# --- AWS (local dev via IAM Identity Center / SSO; set up in Step 1) ---
# No long-lived keys: boto3 reads temporary creds from the SSO profile.
# Run `aws sso login --profile <name>` once per session to refresh them.
AWS_PROFILE=instacart            # the profile name you create with `aws configure sso`
AWS_DEFAULT_REGION=us-east-1
S3_BUCKET=                       # e.g. instacart-raw-<your-initials>

# --- Snowflake (account created in Step 3) ---
SNOWFLAKE_ACCOUNT=               # e.g. ab12345.us-east-1  (Snowsight > account details)
SNOWFLAKE_USER=
SNOWFLAKE_PASSWORD=
SNOWFLAKE_ROLE=INSTACART_ROLE
SNOWFLAKE_WAREHOUSE=INSTACART_WH
SNOWFLAKE_DATABASE=INSTACART
